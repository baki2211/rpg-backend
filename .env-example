# Copy this file to `.env` and fill in real values.
# `src/data-source.js` reads the discrete DB_* vars below — there is no DATABASE_URL.

# Server
NODE_ENV=development
PORT=5001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rpg

# Auth
JWT_SECRET=replace-me-with-a-long-random-string

# CORS — comma-separated allowlist of origins permitted to call the API.
# Leave unset to use the built-in dev default (localhost:3000, localhost:3001, https://arcanerealms.org).
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Optional DB pool / timeout tuning (defaults live in src/data-source.js)
# DB_POOL_SIZE=10
# DB_POOL_MIN=2
# DB_CONNECT_TIMEOUT=10000
# DB_ACQUIRE_TIMEOUT=10000
# DB_TIMEOUT=10000
# DB_IDLE_TIMEOUT=30000
# DB_STATEMENT_TIMEOUT=30000
# DB_QUERY_TIMEOUT=30000
# DB_SLOW_QUERY_THRESHOLD=1000
